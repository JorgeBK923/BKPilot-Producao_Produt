# BugKillers QA Agent — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com os valores reais
# NUNCA commite o arquivo .env no repositório

# Senha do usuário de QA no ambiente de desenvolvimento/homologação
QA_PASSWORD=

# Senha para ambientes adicionais (opcional)
QA_PASSWORD_STAGING=
QA_PASSWORD_PROD=

# Integração com Issue Tracker (opcional — preencha apenas o destinatário)
# Jira Cloud
JIRA_URL=
JIRA_EMAIL=
JIRA_TOKEN=
JIRA_PROJECT_KEY=
# GitHub Issues
GITHUB_REPO=
GITHUB_TOKEN=

# Device farm mobile (Sauce Labs / BrowserStack / LambdaTest etc.)
MOBILE_FARM_USERNAME=
MOBILE_FARM_ACCESS_KEY=
APPIUM_URL=
# NÃO inclua tokens de serviço inline — use este arquivo
